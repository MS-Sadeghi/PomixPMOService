@model IdentityManagementSystem.UI.ViewModels.GetDataReportPageViewModel

@{
    ViewData["Title"] = "گزارش خلاصه تردد";
    Layout = "~/Views/Shared/_AccessControlReportsLayout.cshtml";
}

<link rel="stylesheet" href="~/css/IndexStyle.css" asp-append-version="true" />

<style>
    .dataTables_wrapper .dataTables_filter {
        float: left !important;
    }

    #customExportButtons {
        float: right;
    }
</style>

<div class="card">

<div class="card-header">
    <h5 class="card-title">گزارش خلاصه ترددها</h5>
</div>

<div class="card-body">

    <form id="reportForm">

        <div class="row">

            <div class="col-md-3 mb-3">
                <label>از تاریخ</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="fa fa-calendar"></i>
                    </span>

                    <input name="StartDate"
                           class="form-control fc-datepicker"
                           autocomplete="off" />
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <label>تا تاریخ</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="fa fa-calendar"></i>
                    </span>

                    <input name="EndDate"
                           class="form-control fc-datepicker"
                           autocomplete="off" />
                </div>
            </div>

            <div class="col-md-2 mb-3">
                <label>از ساعت</label>
                <input name="StartTime" type="time" class="form-control" />
            </div>

            <div class="col-md-2 mb-3">
                <label>تا ساعت</label>
                <input name="EndTime" type="time" class="form-control" />
            </div>

            <div class="col-md-2 mb-3">
                <label>مسیر تردد</label>
                <select name="EntranceTypes"
                        class="form-control form-select"
                        multiple>

                    <option value="1">درب شرقی ورود مسیر 1</option>
                    <option value="2">درب شرقی ورود مسیر 2</option>
                    <option value="3">درب شرقی ورود مسیر 3</option>
                    <option value="4">درب غربی خروج</option>
                    <option value="5">درب غربی ورود</option>

                </select>
            </div>

            <div class="col-md-12 text-end">

                <button type="button"
                        id="btnSearch"
                        class="btn btn-primary">

                    <i class="fe fe-search"></i>
                    دریافت گزارش

                </button>

            </div>

        </div>

    </form>

    <hr />

    <div id="errorBox"
         class="alert alert-danger d-none">
    </div>

    <div id="loadingBox"
         class="text-center d-none my-3">

        <div class="spinner-border text-primary"></div>

        <div class="mt-2">
            در حال دریافت اطلاعات ...
        </div>

    </div>

    <div class="table-responsive">

        <table id="reportTable"
               class="table table-bordered table-hover">

            <thead class="table-light">

                <tr>
                    <th>ردیف</th>
                    <th>تاریخ</th>
                    <th>مسیر تردد</th>
                    <th>تعداد</th>
                </tr>

            </thead>

            <tbody>
            </tbody>

        </table>

    </div>

</div>


</div>

@section Scripts
{

<script>

let reportTable;

$(document).ready(function () {

    if (typeof $.fn.persianDatepicker !== "undefined") {

        $(".fc-datepicker").persianDatepicker({
            format: "YYYY/MM/DD",
            autoClose: true
        });

    }

    const now = new Date();

    const currentTime =
        String(now.getHours()).padStart(2,'0')
        + ":" +
        String(now.getMinutes()).padStart(2,'0');

    $("input[name='StartTime']").val("00:00");
    $("input[name='EndTime']").val(currentTime);

   reportTable = $("#reportTable").DataTable({
    destroy: true,
    pageLength: 25,
    responsive: true,
    searching: true,
    ordering: true,
    autoWidth: false,

    language: {
        url: "/assets/datatables/fa.json"
    },

    dom: 'Bfrtip',

    buttons: [
        {
            extend: 'excelHtml5',
            title: 'گزارش_خلاصه_تردد'
        },
        {
            extend: 'pdfHtml5',
            title: 'گزارش_خلاصه_تردد'
        },
        {
            extend: 'print',
            title: 'گزارش_خلاصه_تردد'
        }
    ],

    initComplete: function () {

        // مخفی کردن دکمه‌های پیش‌فرض
        $('.dt-buttons').hide();

        // قرار دادن دکمه‌های سفارشی کنار جستجو
        $('#reportTable_filter').before(`
            <div id="customExportButtons" class="btn-group me-3">
                <button class="btn btn-outline-primary" id="btnPrint">
                    پرینت
                </button>

                <button class="btn btn-outline-success" id="btnExcel">
                    اکسل
                </button>

                <button class="btn btn-outline-danger" id="btnPdf">
                    PDF
                </button>
            </div>
        `);
    }
});

   
});

$(document).on("click", "#btnExcel", function (e) {
    e.preventDefault();
    $(".buttons-excel").click();
});

$(document).on("click", "#btnPdf", function (e) {
    e.preventDefault();
    $(".buttons-pdf").click();
});

$(document).on("click", "#btnPrint", function (e) {
    e.preventDefault();
    $(".buttons-print").click();
});

$("#btnSearch").on("click", function () {

    $("#errorBox")
        .addClass("d-none")
        .removeClass("alert-warning")
        .addClass("alert-danger")
        .html("");

    $("#loadingBox").removeClass("d-none");

    const data = {

        StartDate:
            $("input[name='StartDate']").val(),

        EndDate:
            $("input[name='EndDate']").val(),

        StartTime:
            $("input[name='StartTime']").val(),

        EndTime:
            $("input[name='EndTime']").val(),

        EntranceTypes:
            $("select[name='EntranceTypes']").val()

    };

    $.ajax({

        url: '/AccessControlReports/Report/GetDataReportAjax',

        type: 'POST',

        data: data,

        success: function (res) {

            reportTable.clear();

            let rows = res;

            if (res.data)
                rows = res.data;

            if (!rows || rows.length === 0) {

                reportTable.draw();

                $("#errorBox")
                    .removeClass("d-none")
                    .removeClass("alert-danger")
                    .addClass("alert-warning")
                    .text("داده‌ای یافت نشد");

                return;
            }

            $.each(rows, function (i, item) {

                reportTable.row.add([

                    i + 1,

                    item.reportDate,

                    item.entranceType,

                    '<span class="badge bg-success">' +
                    item.recordCount +
                    '</span>'

                ]);

            });

            reportTable.draw();

        },

        error: function (xhr) {

            let message = "خطا در ارتباط با سرور";

            if (xhr.responseJSON &&
                xhr.responseJSON.message) {

                message =
                    xhr.responseJSON.message;
            }

            $("#errorBox")
                .removeClass("d-none")
                .text(message);

        },

        complete: function () {

            $("#loadingBox")
                .addClass("d-none");

        }

    });

});

</script>

}
