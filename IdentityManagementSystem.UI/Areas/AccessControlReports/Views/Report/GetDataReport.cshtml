@model IdentityManagementSystem.UI.ViewModels.GetDataReportPageViewModel

@{
    ViewData["Title"] = "گزارش خلاصه تردد";
    Layout = "~/Views/Shared/_AccessControlReportsLayout.cshtml";
}

<link rel="stylesheet" href="~/css/IndexStyle.css" asp-append-version="true" />

<div class="card">

    <div class="card-header">
        <h5 class="card-title">گزارش خلاصه ترددها</h5>
    </div>

    <div class="card-body">

        <!-- FILTER -->
        <form id="reportForm">

            <div class="row">

                <div class="col-md-3 mb-3">
                    <label>از تاریخ</label>
                     <div class="input-group">
                        <span class="input-group-text">
                            <i class="fa fa-calendar"></i>
                        </span>

                        <input name="StartDate"
                               class="form-control fc-datepicker"
                               autocomplete="off" />
                    </div>
                </div>

                <div class="col-md-3 mb-3">
                    <label>تا تاریخ</label>
                    <input name="EndDate" class="form-control fc-datepicker" />
                </div>

                <div class="col-md-2 mb-3">
                    <label>از ساعت</label>
                    <input name="StartTime" type="time" class="form-control" />
                </div>

                <div class="col-md-2 mb-3">
                    <label>تا ساعت</label>
                    <input name="EndTime" type="time" class="form-control" />
                </div>

                <div class="col-md-2 mb-3">
                    <label>نوع تردد</label>
                    <select name="EntranceType" class="form-control form-select">
                        <option value="">انتخاب کنید</option>
                        <option value="1">درب شرقی ورود مسیر 1</option>
                        <option value="2">درب شرقی ورود مسیر 2</option>
                        <option value="3">درب شرقی ورود مسیر 3</option>
                        <option value="4">درب غربی خروج</option>
                        <option value="5">درب غربی ورود</option>
                    </select>
                </div>

                <div class="col-md-12 text-end mb-3">
                    <button type="button" id="btnSearch" class="btn btn-primary">
                        <i class="fe fe-search"></i> دریافت گزارش
                    </button>
                </div>

            </div>

        </form>

        <!-- EXPORT -->
        <div class="btn-group mb-3">
            <button class="btn btn-outline-primary" id="btnPrint">پرینت</button>
            <button class="btn btn-outline-primary" id="btnExcel">اکسل</button>
            <button class="btn btn-outline-primary" id="btnPdf">PDF</button>
        </div>

        <!-- TABLE -->
        <div class="table-responsive">
            <table class="table table-bordered table-hover text-nowrap">
                <thead class="table-light">
                    <tr>
                        <th>ردیف</th>
                        <th>تاریخ</th>
                        <th>نوع تردد</th>
                        <th>تعداد</th>
                    </tr>
                </thead>
                <tbody id="reportBody">
                    <tr>
                        <td colspan="4" class="text-center">اطلاعاتی موجود نیست</td>
                    </tr>
                </tbody>
            </table>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            if (typeof $.fn.persianDatepicker === "undefined") {
                console.error("Persian Datepicker is NOT loaded");
                return;
            }

            $(".fc-datepicker").persianDatepicker({
                format: "YYYY/MM/DD",
                autoClose: true
            });

            // ⬇️ تنظیم ساعت فعلی
            var now = new Date();

            var hours = String(now.getHours()).padStart(2, '0');
            var minutes = String(now.getMinutes()).padStart(2, '0');

            var currentTime = hours + ":" + minutes;

            $("input[name='StartTime']").val("00:00");
            $("input[name='EndTime']").val(currentTime);
        });

        $("#btnSearch").click(function () {

            var data = {
                StartDate: $("input[name='StartDate']").val(),
                EndDate: $("input[name='EndDate']").val(),
                StartTime: $("input[name='StartTime']").val(),
                EndTime: $("input[name='EndTime']").val(),
                EntranceType: $("select[name='EntranceType']").val()
            };

            $.ajax({
                url: '/AccessControlReports/Report/GetDataReportAjax',
                type: 'POST',
                data: data,
                success: function (res) {

                    var rows = "";

                    if (res.length === 0) {
                        rows = `<tr><td colspan="4" class="text-center">داده‌ای یافت نشد</td></tr>`;
                    } else {
                        $.each(res, function (i, item) {
                            rows += `
                                <tr>
                                    <td>${i + 1}</td>
                                    <td>${item.reportDate}</td>
                                    <td>${item.entranceType}</td>
                                    <td><span class="badge bg-success">${item.recordCount}</span></td>
                                </tr>`;
                        });
                    }

                    $("#reportBody").html(rows);
                }
            });

        });
    </script>
}