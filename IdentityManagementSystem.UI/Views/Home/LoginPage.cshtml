@model IdentityManagementSystem.UI.ViewModels.LoginViewModel
@using DNTCaptcha.Core
@{
    ViewData["Title"] = "ورود به سامانه";
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
}

<style>
    .login-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        padding: 20px;
    }

    .row.w-100 {
        display: flex;
        justify-content: center;
        align-items: center;
        margin: 0 auto;
    }

    .login-right {
        flex: 0 0 450px;
        background: rgba(255, 255, 255, 0.25);
        backdrop-filter: blur(12px);
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 8px 32px rgba(31, 38, 135, 0.2);
        border: 1px solid rgba(255, 255, 255, 0.3);
        transition: transform 0.3s ease;
    }

        .login-right:hover {
            transform: translateY(-5px);
        }

    .btn-primary {
        border: none;
        padding: 12px;
        width: 100%;
        border-radius: 5px;
        font-weight: 500;
        color: #fff;
        transition: background 0.3s ease;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-control {
        border: 1px solid #ccc;
        border-radius: 8px;
        height: 45px;
        padding: 10px;
    }

    .captchaInput {
        height: 45px !important;
        border-radius: 8px !important;
        border: 1px solid #ccc !important;
        padding: 10px !important;
        width: 100% !important;
        text-align: right !important;
        direction: rtl !important;
    }

    .captcha-container img {
        margin-left: 10px !important;
        margin-right: 0 !important;
    }

    .captcha-refresh-btn {
        margin-left: 10px !important;
        margin-right: 0 !important;
    }

    .captcha-group {
        direction: rtl !important;
        text-align: right !important;
    }

    .form-group {
        margin-bottom: 20px;
        position: relative;
    }

    .input-group {
        position: relative;
        width: 100%;
    }

    .form-control {
        border: 1px solid #ccc;
        border-radius: 8px;
        height: 45px;
        padding: 10px;
        width: 100%;
    }

    .input-group-text {
        border-top-right-radius: 8px;
        border-bottom-right-radius: 8px;
    }

    .form-control:focus {
        border-color: #86b7fe;
        outline: 0;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
    }

    .wrap-input100 {
        margin-bottom: 5px;
    }

    .login-right form > div {
        margin-bottom: 20px;
    }
</style>

<div class="login-container">
    <div class="row w-100" style="max-width: 400px;">
        <div class="login-right">
            <h3 class="text-center pb-3">سامانه استعلام سند</h3>
            <form id="loginForm"  method="post" autocomplete="off" action="/Home/LoginPage">
                @Html.AntiForgeryToken()

                <!-- Username Input -->
                <div class="form-group mb-3">
                    <div class="input-group">
                        <span class="input-group-text bg-white text-muted">
                            <i class="zmdi zmdi-account text-muted" aria-hidden="true"></i>
                        </span>
                        <input asp-for="Username"
                               class="form-control"
                               placeholder="نام کاربری"
                               autocomplete="username"
                               required />
                    </div>
                    <span asp-validation-for="Username" class="text-danger d-block mt-1"></span>
                </div>

                <!-- Password Input -->
                <div class="form-group mb-3">
                    <div class="input-group" id="Password-toggle">
                        <span class="input-group-text bg-white text-muted">
                            <i class="zmdi zmdi-eye" aria-hidden="true"></i>
                        </span>
                        <input asp-for="Password"
                               type="password"
                               class="form-control"
                               placeholder="رمز عبور"
                               autocomplete="current-password"
                               required />
                    </div>
                    <span asp-validation-for="Password" class="text-danger d-block mt-1"></span>
                </div>

                <!-- Captcha Section -->
                @* <div id="securitySection" class="form-group text-start mt-2" style="direction: rtl;"> *@
                    <dnt-captcha asp-captcha-generator-max="9999"
                                 asp-captcha-generator-min="1000"
                                 asp-captcha-generator-language="English"
                                 asp-captcha-generator-display-mode="ShowDigits"
                                 asp-use-relative-urls="true"
                                 asp-placeholder="کد امنیتی را وارد کنید"
                                 asp-validation-error-message="کد امنیتی اشتباه است."
                                 asp-too-many-requests-error-message="درخواست‌های زیاد! لطفاً یک دقیقه صبر کنید!"
                                 asp-font-name="Tahoma"
                                 asp-font-size="30"
                                 asp-fore-color="#333333"
                                 asp-back-color="#FCF6F5FF"
                                 asp-text-box-class="form-control captchaInput"
                                 asp-text-box-template="<div class='form-group'>{0}</div>"
                                 asp-validation-message-class="text-danger"
                                 asp-refresh-button-class="bx bx-sync btn"
                                 asp-show-refresh-button="true" />
                @* </div> *@

                <!-- Submit Button -->
                <div class="form-group mt-3">
                    <button type="submit" class="btn btn-primary mb-1">ورود</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        @if (TempData["SuccessLogoutMessage"] != null)
        {
                    @:toastr.options = {
                    @:"closeButton": true,
                    @:"progressBar": true,
                    @:"positionClass": "toast-top-left",
                    @:"timeOut": "3000",
                    @:"rtl": true
                    @:};
                    @:toastr.success('@TempData["SuccessLogoutMessage"]');
        }

        const jwtToken = '@ViewBag.JwtToken';
        if (jwtToken) {
            localStorage.setItem('jwtToken', jwtToken);
            window.location.href = '/JudiciaryInquiry/Cartable/Index';
        }

        document.addEventListener('DOMContentLoaded', function () {
            toastr.options = {
                "closeButton": true,
                "progressBar": true,
                "positionClass": "toast-top-left",
                "timeOut": "5000",
                "rtl": true
            };

            const validationErrors = document.querySelectorAll('.field-validation-error, .text-danger');
            validationErrors.forEach(err => {
                const text = err.textContent.trim();
                if (text !== '' && text.length > 5) {
                    toastr.error(text);
                }
            });

            if ('@(!string.IsNullOrEmpty(ViewBag.ErrorMessage) ? ViewBag.ErrorMessage : "")' !== '') {
                toastr.error('@(!string.IsNullOrEmpty(ViewBag.ErrorMessage) ? ViewBag.ErrorMessage : "")');
            }

            const toggle = document.getElementById('Password-toggle');
            const icon = toggle.querySelector('i');
            const input = toggle.querySelector('input');

            toggle.addEventListener('click', function (e) {
                if (e.target.closest('span.input-group-text')) {
                    if (input.type === 'password') {
                        input.type = 'text';
                        icon.classList.remove('zmdi-eye');
                        icon.classList.add('zmdi-eye-off');
                    } else {
                        input.type = 'password';
                        icon.classList.remove('zmdi-eye-off');
                        icon.classList.add('zmdi-eye');
                    }
                }
            });
        });
    </script>
}
