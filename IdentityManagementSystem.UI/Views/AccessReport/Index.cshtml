@{
    // ViewData["Title"] = "داشبورد";
    Layout = "~/Views/Shared/_LayoutAccessReport.cshtml";
}

<div class="row">

    <!-- Welcome -->
    <div class="col-xl-12">
        <div class="card bg-primary-transparent">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="fw-bold mb-1">
                        سامانه جامع گزارشات تردد
                    </h4>
                    <p class="mb-0 text-muted">
                        به داشبورد سامانه خوش آمدید.
                    </p>
                </div>
                <i class="fe fe-bar-chart-2 fs-90 text-primary"></i>
            </div>
        </div>
    </div>

    <!-- Statistics -->
    <div class="col-xl-3 col-lg-6">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="text-muted">کل تردد امروز</h6>
                        <h2>14,582</h2>
                    </div>
                    <div class="avatar bg-primary-transparent">
                        <i class="fe fe-activity"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-lg-6">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="text-muted">تردد خودروها</h6>
                        <h2>9,248</h2>
                    </div>
                    <div class="avatar bg-success-transparent">
                        <i class="fe fe-truck"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-lg-6">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="text-muted">تردد افراد</h6>
                        <h2>5,334</h2>
                    </div>
                    <div class="avatar bg-info-transparent">
                        <i class="fe fe-users"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-lg-6">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="text-muted">گزارش‌های امروز</h6>
                        <h2>163</h2>
                    </div>
                    <div class="avatar bg-warning-transparent">
                        <i class="fe fe-file-text"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Chart -->
    <div class="col-xl-8">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    روند تردد هفت روز اخیر
                </h3>
            </div>
            <div class="card-body">
                <div style="height:350px;background:#f8f9fa;border-radius:8px;display:flex;align-items:center;justify-content:center;">
                    نمودار Line Chart
                </div>
            </div>
        </div>
    </div>

    <!-- Status -->
    <div class="col-xl-4">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    وضعیت سامانه
                </h3>
            </div>
            <div class="card-body">
                <div class="mb-4">

                    🟢 وب سرویس تردد

                </div>

                <div class="mb-4">

                    🟢 پایگاه داده

                </div>

                <div class="mb-4">

                    🟢 آخرین بروزرسانی

                    <br>

                    09:42

                </div>

                <div>

                    🔵 نسخه سامانه

                    <br>

                    1.0.0

                </div>

            </div>

        </div>

    </div>



    <!-- Quick Access -->

    <div class="col-xl-12">

        <div class="card">

            <div class="card-header">

                <h3 class="card-title">

                    دسترسی سریع به گزارش‌ها

                </h3>

            </div>

            <div class="card-body">

                <div class="row">


                    <div class="col-lg col-md-4 col-6">                   
                        <a asp-controller="AccessReport" asp-action="GetDataReport">


                        <div class="card border text-center">

                            <div class="card-body">
                                    <i class="fe fe-list fs-30 text-primary"></i>

                                    <h6 class="mt-3">

                                        خالصه تردد

                                    </h6>
                            </div>

                        </div>
                        </a>

                        </div>


                    <div class="col-lg col-md-4 col-6">
                    <a asp-controller="AccessReport" asp-action="GetSumReport">

                        <div class="card border text-center">

                            <div class="card-body">

                                    <i class="fe fe-layers fs-30 text-success"></i>

                                    <h6 class="mt-3">

                                        گزارش تجمیعی

                                    </h6>
                            </div>

                        </div>
                        </a>

                        </div>


                    <div class="col-lg col-md-4 col-6">
                    <a asp-controller="AccessReport" asp-action="TrafficByTypeReport">

                        <div class="card border text-center">

                            <div class="card-body">

                                    <i class="fe fe-truck fs-30 text-warning"></i>

                                    <h6 class="mt-3">

                                        نوع تردد

                                    </h6>
                            </div>

                        </div>
                        </a>

                        </div>


                    <div class="col-lg col-md-4 col-6">
                    <a asp-controller="AccessReport" asp-action="TrafficByPlatesReport">

                        <div class="card border text-center">

                            <div class="card-body">

                                    <i class="fe fe-credit-card fs-30 text-info"></i>

                                    <h6 class="mt-3">

                                        پلاک

                                    </h6>
                            </div>

                        </div>
                        </a>

                        </div>


                    <div class="col-lg col-md-4 col-6">
                    <a asp-controller="AccessReport" asp-action="TrafficByNationalIDReport">

                        <div class="card border text-center">

                            <div class="card-body">

                                    <i class="fe fe-user fs-30 text-danger"></i>

                                    <h6 class="mt-3">

                                        کد ملی

                                </h6>
                            </div>

                        </div>
                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>



    <!-- Bottom -->

    <div class="col-xl-5">
        r
        <div class="card">

            <div class="card-header">

                <h3 class="card-title">

                    انواع تردد

                </h3>

            </div>

            <div class="card-body">

                <div style="height:280px;background:#f8f9fa;border-radius:8px;display:flex;align-items:center;justify-content:center;">

                    Pie Chart

                </div>

            </div>

        </div>

    </div>


    <div class="col-xl-7">

        <div class="card">

            <div class="card-header">

                <h3 class="card-title">

                    آخرین گزارش‌های مشاهده شده

                </h3>

            </div>

            <div class="card-body">

                <table class="table table-bordered">

                    <thead>

                        <tr>

                            <th>عنوان گزارش</th>

                            <th>تاریخ</th>

                            <th>کاربر</th>

                        </tr>

                    </thead>

                    <tbody>

                        <tr>

                            <td>گزارش پلاک</td>

                            <td>1405/05/12</td>

                            <td>مدیر سیستم</td>

                        </tr>

                        <tr>

                            <td>گزارش کد ملی</td>

                            <td>1405/05/12</td>

                            <td>کارشناس</td>

                        </tr>

                        <tr>

                            <td>گزارش خالصه تردد</td>

                            <td>1405/05/11</td>

                            <td>مدیر</td>

                        </tr>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>