@model IEnumerable<IdentityManagementSystem.UI.ViewModels.UserViewModel>
@{
    ViewData["Title"] = "کاربران";
    Layout = "_Layout";
}

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
}

<div class="input-group mb-5">
    <input type="text" class="form-control" placeholder="جستجو" id="searchInput">
    <button class="btn btn-primary" id="searchButton">
        <i class="fa fa-search" aria-hidden="true"></i> جستجو
    </button>
</div>

<div class="card">
    <div class="card-header d-flex align-items-center">
        <h2 class="card-title">کاربران</h2>
        <button id="AddUser" type="button" class="btn btn-primary btn-pill left-btn">افزودن کاربر</button>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(ViewBag.SuccessMessage))
        {
            <div class="alert alert-success">@ViewBag.SuccessMessage</div>
        }
        @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
        {
            <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
        }
        <div class="table-responsive">
            <table class="table table-bordered border text-nowrap mb-0" id="usersTable">
                <thead>
                    <tr>
                        <th>نام</th>
                        <th>نام خانوادگی</th>
                        <th>موقعیت</th>
                        <th>نام کاربری</th>
                        <th>تاریخ ثبت</th>
                        <th>آخرین ورود</th>
                        <th>عملیات</th>
                    </tr>
                </thead>
                <tbody id="usersTableBody">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var user in Model)
                        {
                            <tr data-user-id="@user.UserId">
                                <td>@user.Name</td>
                                <td>@user.LastName</td>
                                <td>@user.Role</td>
                                <td>@user.Username</td>
                                <td>@(user.CreatedAt?.ToString("yyyy/MM/dd") ?? "-")</td>
                                <td>@(user.LastLogin?.ToString("yyyy/MM/dd HH:mm") ?? "-")</td>
                                <td>
                                    <button class="btn btn-sm btn-info btn-edit" data-id="@user.UserId">
                                        <i class="fa fa-edit"></i> 
                                    </button>
                                    <button class="btn btn-sm btn-danger btn-delete" data-id="@user.UserId">
                                        <i class="fa fa-trash"></i> 
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr id="noDataRow">
                            <td colspan="7" class="text-center">هیچ کاربری یافت نشد.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal افزودن کاربر  -->
<div class="modal fade" id="addUserModal" tabindex="-1" aria-labelledby="addUserModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content modal-content-demo">
            <div class="modal-header">
                <h6 class="modal-title" id="addUserModalLabel">افزودن کاربر جدید</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="بستن"><span aria-hidden="true">×</span></button>
            </div>
            <div class="modal-body">
                <form id="createUserForm" asp-controller="Home" asp-action="CreateUser" method="post" class="needs-validation" novalidate>
                    @Html.AntiForgeryToken()
                    <div class="form-row">
                        <div class="col-xl-6 mb-3">
                            <label for="Name">نام</label>
                            <input class="form-control" id="Name" name="Name" required>
                            <div class="valid-feedback">معتبر است!</div>
                            <div class="invalid-feedback">لطفاً نام را وارد کنید.</div>
                        </div>
                        <div class="col-xl-6 mb-3">
                            <label for="LastName">نام خانوادگی</label>
                            <input class="form-control" id="LastName" name="LastName" required>
                            <div class="valid-feedback">معتبر است!</div>
                            <div class="invalid-feedback">لطفاً نام خانوادگی را وارد کنید.</div>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="col-xl-6 mb-3">
                            <label for="Username">نام کاربری</label>
                            <input class="form-control" id="Username" name="Username" required>
                            <div class="valid-feedback">معتبر است!</div>
                            <div class="invalid-feedback">لطفاً نام کاربری را وارد کنید.</div>
                        </div>
                        <div class="col-xl-6 mb-3">
                            <label for="NationalId">کد ملی</label>
                            <input class="form-control" id="NationalId" name="NationalId" required maxlength="10">
                            <div class="valid-feedback">معتبر است!</div>
                            <div class="invalid-feedback">لطفاً کد ملی را وارد کنید.</div>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="col-xl-6 mb-3">
                            <label for="RoleId">نقش کاربر</label>
                            <select class="form-control" id="RoleId" name="RoleId" required>
                                <option value="">در حال بارگذاری...</option>
                            </select>
                            <div class="valid-feedback">معتبر است!</div>
                            <div class="invalid-feedback">لطفاً نقش کاربر را انتخاب کنید.</div>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="col-xl-6 mb-3">
                            <label for="Password">رمز عبور</label>
                            <div class="wrap-input100 validate-input input-group" id="Password-toggle1">
                                <a href="javascript:void(0)" class="input-group-text bg-white text-muted toggle-password">
                                    <i class="zmdi zmdi-eye text-muted" aria-hidden="true"></i>
                                </a>
                                <input class="input100 form-control" type="password" id="Password" name="Password" placeholder="رمز عبور" autocomplete="new-password" required minlength="6">
                            </div>
                            <div class="valid-feedback">معتبر است!</div>
                            <div class="invalid-feedback">لطفاً رمز عبور را وارد کنید (حداقل 6 کاراکتر).</div>
                        </div>
                        <div class="col-xl-6 mb-3">
                            <label for="ConfirmPassword">تأیید رمز عبور</label>
                            <div class="wrap-input100 validate-input input-group" id="Password-toggle2">
                                <a href="javascript:void(0)" class="input-group-text bg-white text-muted toggle-password">
                                    <i class="zmdi zmdi-eye text-muted" aria-hidden="true"></i>
                                </a>
                                <input class="input100 form-control" type="password" id="ConfirmPassword" name="ConfirmPassword" placeholder="تأیید رمز عبور" autocomplete="new-password" required>
                            </div>
                            <div class="valid-feedback">معتبر است!</div>
                            <div class="invalid-feedback">لطفاً تأیید رمز عبور را وارد کنید.</div>
                            <div id="passwordMismatch" class="invalid-feedback d-none">رمز عبور و تأیید رمز عبور باید یکسان باشند.</div>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button class="btn btn-primary" type="submit">ثبت کاربر</button>
                        <button class="btn btn-light" type="button" data-bs-dismiss="modal">بستن</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal ویرایش کاربر -->
<div class="modal fade" id="editUserModal" tabindex="-1" aria-labelledby="editUserModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content modal-content-demo">
            <div class="modal-header">
                <h6 class="modal-title" id="editUserModalLabel">ویرایش کاربر</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="بستن"></button>
            </div>
            <div class="modal-body">
                <form id="editUserForm" asp-controller="Home" asp-action="UpdateUser" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="editUserId" name="UserId" />
                    
                    <div class="form-row">
                        <div class="col-xl-6 mb-3">
                            <label for="editName">نام</label>
                            <input class="form-control" id="editName" name="Name" >
                        </div>
                        <div class="col-xl-6 mb-3">
                            <label for="editLastName">نام خانوادگی</label>
                            <input class="form-control" id="editLastName" name="LastName" >
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="col-xl-6 mb-3">
                            <label for="editUsername">نام کاربری</label>
                            <input class="form-control" id="editUsername" name="Username" >
                        </div>
                        <div class="col-xl-6 mb-3">
                            <label for="editNationalId">کد ملی</label>
                            <input class="form-control" id="editNationalId" name="NationalId"  maxlength="10">
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="col-xl-6 mb-3">
                            <label for="editRoleId">نقش کاربر</label>
                            <select class="form-control" id="editRoleId" name="RoleId">
                                <option value="">انتخاب کنید</option>
                            </select>
                        </div>
                        <div class="col-xl-6 mb-3">
                            <label for="editMobileNumber">شماره موبایل</label>
                            <input class="form-control" id="editMobileNumber" name="MobileNumber">
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="col-xl-6 mb-3">
                            <label for="editPassword">رمز عبور جدید</label>
                            <input class="form-control" type="password" id="editPassword" name="Password" minlength="6">
                        </div>
                        <div class="col-xl-6 mb-3">
                            <label for="editConfirmPassword">تأیید رمز عبور</label>
                            <input class="form-control" type="password" id="editConfirmPassword" name="ConfirmPassword">
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button class="btn btn-primary" type="submit">به‌روزرسانی</button>
                        <button class="btn btn-light" type="button" data-bs-dismiss="modal">بستن</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    // استفاده از vanilla JavaScript به جای jQuery
    document.addEventListener('DOMContentLoaded', function() {
        let addModal, editModal;

        // مقداردهی مودال‌ها
        addModal = new bootstrap.Modal(document.getElementById('addUserModal'));
        editModal = new bootstrap.Modal(document.getElementById('editUserModal'));

        // بارگذاری نقش‌ها برای مودال افزودن
        loadRolesForModal('RoleId');
        loadRolesForModal('editRoleId');

        // دکمه افزودن کاربر
        document.getElementById('AddUser').addEventListener('click', function() {
            document.getElementById('createUserForm').reset();
            document.getElementById('createUserForm').classList.remove('was-validated');
            addModal.show();
        });

        // جستجو
        function filterTable() {
            var searchText = document.getElementById('searchInput').value.toLowerCase();
            var rows = document.querySelectorAll('#usersTableBody tr');

            rows.forEach(function(row) {
                if (row.id === 'noDataRow') return;

                var text = row.textContent.toLowerCase();
                if (text.indexOf(searchText) > -1) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }

        document.getElementById('searchInput').addEventListener('keyup', filterTable);
        document.getElementById('searchButton').addEventListener('click', filterTable);

        // ویرایش کاربر
        document.querySelectorAll('.btn-edit').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var userId = this.dataset.id;

                fetch('@Url.Action("EditUser", "Home")?id=' + userId, {
                    method: 'GET',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                })
                .then(response => response.json())
                .then(response => {
                    if (response.success) {
                        document.getElementById('editUserId').value = response.userId;
                        document.getElementById('editName').value = response.name;
                        document.getElementById('editLastName').value = response.lastName;
                        document.getElementById('editUsername').value = response.username;
                        document.getElementById('editNationalId').value = response.nationalId;
                        document.getElementById('editMobileNumber').value = response.mobileNumber || '';
                        document.getElementById('editRoleId').value = response.roleId;
                        document.getElementById('editPassword').value = '';
                        document.getElementById('editConfirmPassword').value = '';
                        editModal.show();
                    } else {
                        alert(response.message);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('خطا در دریافت اطلاعات کاربر');
                });
            });
        });

        // حذف کاربر
        document.querySelectorAll('.btn-delete').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var userId = this.dataset.id;
                if (confirm('آیا از حذف این کاربر اطمینان دارید؟')) {

                    var token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                    fetch('@Url.Action("SoftDeleteUser", "Home")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': token
                        },
                        body: 'id=' + userId
                    })
                    .then(response => response.json())
                    .then(response => {
                        if (response.success) {
                            alert(response.message);
                            setTimeout(function() {
                                location.reload();
                            }, 1000);
                        } else {
                            alert(response.message);
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        alert('خطا در حذف کاربر');
                    });
                }
            });
        });

    // ارسال فرم ویرایش
    document.getElementById('editUserForm').addEventListener('submit', function(e) {
        e.preventDefault();

        var password = document.getElementById('editPassword').value;
        var confirmPassword = document.getElementById('editConfirmPassword').value;

        // فقط بررسی رمز عبور در صورتی که پر شده باشد
        if (password && password !== confirmPassword) {
            alert('رمز عبور و تأیید رمز عبور یکسان نیستند');
            return;
        }

        var form = this;
        var formData = new FormData(form);
        var urlEncodedData = new URLSearchParams(formData).toString();
        var token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        fetch(form.action, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': token
            },
            body: urlEncodedData
        })
        .then(response => response.json())
        .then(response => {
            if (response.success) {
                alert('کاربر با موفقیت به‌روزرسانی شد');
                editModal.hide();
                setTimeout(function() {
                    location.reload();
                }, 1000);
            } else {
                alert(response.message || 'خطا در به‌روزرسانی');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('خطا در به‌روزرسانی کاربر');
        });
    });

        // ارسال فرم ایجاد کاربر
        document.getElementById('createUserForm').addEventListener('submit', function(e) {
            e.preventDefault();

            var password = document.getElementById('Password').value;
            var confirmPassword = document.getElementById('ConfirmPassword').value;

            if (password !== confirmPassword) {
                alert('رمز عبور و تأیید رمز عبور یکسان نیستند');
                return;
            }

            var form = this;
            var formData = new FormData(form);
            var urlEncodedData = new URLSearchParams(formData).toString();
            var token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            fetch(form.action, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: urlEncodedData
            })
            .then(response => response.json())
            .then(response => {
                if (response.success) {
                    alert('کاربر با موفقیت ایجاد شد');
                    addModal.hide();
                    setTimeout(function() {
                        location.reload();
                    }, 1000);
                } else {
                    alert(response.message || 'خطا در ایجاد کاربر');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('خطا در ایجاد کاربر');
            });
        });

        // بستن مودال‌ها
        document.getElementById('addUserModal').addEventListener('hidden.bs.modal', function() {
            document.getElementById('createUserForm').reset();
            document.getElementById('createUserForm').classList.remove('was-validated');
        });

        document.getElementById('editUserModal').addEventListener('hidden.bs.modal', function() {
            document.getElementById('editUserForm').reset();
        });
    });

    // تابع بارگذاری نقش‌ها
    function loadRolesForModal(selectId) {
        fetch('@Url.Action("GetRoles", "Home")', {
            method: 'GET',
            headers: {
                'Content-Type': 'application/json'
            }
        })
        .then(response => response.json())
        .then(roles => {
            var $roleSelect = document.getElementById(selectId);
            $roleSelect.innerHTML = '<option value="">انتخاب کنید</option>';

            if (roles && Array.isArray(roles) && roles.length > 0) {
                roles.forEach(function(role) {
                    var option = document.createElement('option');
                    option.value = role.roleId;
                    option.textContent = role.roleName;
                    $roleSelect.appendChild(option);
                });
            }
        })
        .catch(error => {
            console.error('Error loading roles:', error);
            document.getElementById(selectId).innerHTML = '<option value="">خطا در بارگذاری</option>';
        });
    }
</script>